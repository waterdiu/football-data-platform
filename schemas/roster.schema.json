{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Roster",
  "type": "object",
  "required": ["competition_id", "season_id", "team_id", "source_status", "players"],
  "properties": {
    "competition_id": { "type": "string" },
    "season_id": { "type": "string" },
    "team_id": { "type": "string" },
    "team_name": { "type": ["string", "null"] },
    "roster_type": { "type": "string" },
    "source_status": { "type": "string" },
    "confidence": { "type": "string" },
    "published_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] },
    "sources": { "type": "array", "items": { "type": "string" } },
    "source_refs": { "type": "object" },
    "players": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["player_id", "name"],
        "properties": {
          "player_id": { "type": "string" },
          "name": { "type": "string" },
          "position": { "type": ["string", "null"] },
          "shirt_number": { "type": ["number", "null"] },
          "club": { "type": ["string", "null"] },
          "status": { "type": ["string", "null"] }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
