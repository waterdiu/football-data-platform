{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TeamWorldCupHistory",
  "type": "object",
  "required": ["team_id", "competition_id", "source_status", "summary", "editions", "updated_at"],
  "properties": {
    "team_id": { "type": "string" },
    "team_name": { "type": "string" },
    "competition_id": { "type": "string" },
    "source_status": { "type": "string" },
    "source": { "type": ["string", "null"] },
    "summary": {
      "type": "object",
      "properties": {
        "appearances": { "type": "integer" },
        "completed_appearances": { "type": "integer" },
        "current_qualified": { "type": "boolean" },
        "best_finish": { "type": ["string", "null"] },
        "matches_played": { "type": "integer" },
        "won": { "type": "integer" },
        "drawn": { "type": "integer" },
        "lost": { "type": "integer" },
        "goals_for": { "type": "integer" },
        "goals_against": { "type": "integer" }
      }
    },
    "editions": {
      "type": "array",
      "items": { "type": "object" }
    },
    "notes": { "type": "string" },
    "updated_at": { "type": "string" }
  }
}
